// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "colorize_brackets": true,
  "indent_guides": {
    "background_coloring": "indent_aware",
    "coloring": "indent_aware",
  },
  "tab_size": 2,
  "document_symbols": "on",
  "document_folding_ranges": "on",
  "semantic_tokens": "combined",
  "file_finder": {
    "modal_max_width": "large",
  },
  "cli_default_open_behavior": "new_window",
  "diff_view_style": "split",
  "minimap": {
    "show": "always",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "code_lens": "on",
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "git_panel": {
    "file_icons": true,
    "tree_view": true,
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "github-copilot-cli": {
      "favorite_config_option_values": {
        "model": ["gpt-5.5", "gpt-5-mini", "claude-sonnet-4.6"],
      },
      "default_config_options": {
        "model": "gpt-5.5",
      },
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "icon_theme": "VSCode Great Icons Theme",
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-5.2-codex",
      },
    ],
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.2-codex",
    },
    "default_profile": "write",
    "model_parameters": [],
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5",
    },
  },
  "autosave": "on_focus_change",
  "theme": "Everforest Dark Soft",
  "telemetry": {
    "metrics": false,
  },
  "vim_mode": true,
  "ui_font_size": 13.0,
  "ui_font_family": "Monaspace Neon NF",
  "buffer_font_size": 12.3,
  "buffer_font_family": "Monaspace Neon NF",
  "terminal": { "font_family": "Monaspace Neon NF" },
  "languages": {
    "Ruby": {
      "language_servers": [
        "ruby-lsp",
        "!rubocop",
        "!solargraph",
        "!sorbet",
        "!steep",
        "!kanayago",
        "!fuzzy-ruby-server",
        "...",
      ],
    },
    "YAML": {
      "formatter": "language_server",
    },
  },
}
